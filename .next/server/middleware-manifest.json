      ],
      "name": "src/middleware",
      "page": "/",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/profile(?:\\/((?:[^\\/#\\?]+?)(?:\\/(?:[^\\/#\\?]+?))*))?(.json)?[\\/#\\?]?$",
          "originalSource": "/profile/:path*"
        }
      ],
      "wasm": [],
      "assets": []
    }
  },
  "functions": {
    "/api/login/route": {
      "files": [
        "server/middleware-build-manifest.js",
        "server/middleware-react-loadable-manifest.js",
        "server/next-font-manifest.js",
        "prerender-manifest.js",
        "server/edge-runtime-webpack.js",
        "server/app/api/login/route.js"
      ],
      "name": "app/api/login/route",
      "page": "/api/login/route",
      "matchers": [
        {
          "regexp": "^/api/login$",
          "originalSource": "/api/login"
        }
      ],
      "wasm": [],
      "assets": []
    },
    "/api/upload-avatar/route": {
      "files": [
        "server/middleware-build-manifest.js",
        "server/middleware-react-loadable-manifest.js",
        "server/next-font-manifest.js",
        "prerender-manifest.js",
        "server/edge-runtime-webpack.js",
        "server/app/api/upload-avatar/route.js"
      ],
      "name": "app/api/upload-avatar/route",
      "page": "/api/upload-avatar/route",
      "matchers": [
        {
          "regexp": "^/api/upload\\-avatar$",
          "originalSource": "/api/upload-avatar"
        }
      ],
      "wasm": [],
      "assets": []
    }
  },
  "version": 2
}